BILI_SUBTITLE_CONFIG_FILE=/config/service.yaml
BILI_SUBTITLE_HOST_PORT=8310
BILI_SUBTITLE_MCP_HOST_PORT=8311
# Optional overrides. Prefer config file for stable deployment defaults.
# BILI_SUBTITLE_TIMEOUT_SECONDS=15
# BILI_SUBTITLE_USER_AGENT=Mozilla/5.0 (...)
# BILI_SUBTITLE_PROXY=http://proxy:7890
# BILI_SUBTITLE_COOKIE_FILE=/run/secrets/bilibili_cookie
# A bare SESSDATA value is accepted and normalized to SESSDATA=...
# BILI_SUBTITLE_COOKIE=SESSDATA=...; bili_jct=...
# BILI_SUBTITLE_SUMMARY_MODEL=deepseek-v4-flash
# BILI_SUBTITLE_SUMMARY_REASONING_EFFORT=high
